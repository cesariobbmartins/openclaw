# pnpm build-script allowlist lives in package.json -> pnpm.onlyBuiltDependencies.

# Hoist extension deps to root node_modules so they survive multi-stage Docker COPY.
# Without this, pnpm symlinks in extensions/*/node_modules/ break across stages.
public-hoist-pattern[]=pg
public-hoist-pattern[]=google-auth-library
public-hoist-pattern[]=googleapis
public-hoist-pattern[]=@sinclair/typebox
