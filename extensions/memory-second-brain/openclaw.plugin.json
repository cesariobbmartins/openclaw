{
  "id": "memory-second-brain",
  "kind": "memory",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["org", "agentId"],
    "properties": {
      "org": {
        "type": "string",
        "description": "Organization ID (e.g. 'zoop')"
      },
      "agentId": {
        "type": "string",
        "description": "Agent ID (e.g. 'cesario')"
      },
      "workspacePath": {
        "type": "string",
        "description": "GCS FUSE mount point or local dev path",
        "default": "/workspaces"
      },
      "supabaseUrl": {
        "type": "string",
        "description": "Supabase project URL (or ${SUPABASE_URL})"
      },
      "supabaseKey": {
        "type": "string",
        "description": "Supabase service role key (or ${SUPABASE_KEY})"
      },
      "dailyTailLines": {
        "type": "number",
        "description": "How many lines of today's daily log to inject",
        "default": 100
      }
    }
  }
}
